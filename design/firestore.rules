rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public product catalog
    match /categories/{doc} {
      allow read: if true;
      allow write: if true;
    }

    match /products/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // User profiles, keyed by auth UID
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Orders mirrored from the storefront for admin
    match /orders/{orderId} {
      // Allow anyone (even guests) to place an order
      allow create: if true;

      // Allow authenticated customers to read/update their own orders
      allow read, update, delete: if
        request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // Default deny for anything not explicitly matched above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

